<%- include('partials/admin_header') %>

<!-- Main Content Area -->
<main class="flex-1 overflow-y-auto px-6 py-10 lg:px-12">
<div class="max-w-4xl mx-auto w-full">
<div class="mb-10">
<h1 class="text-slate-100 text-4xl font-black leading-tight tracking-tight mb-2">Thêm sản phẩm mới</h1>
<p class="text-slate-400 text-base font-normal">Tải lên video và cấu hình thông tin cho dự án AI mới.</p>
</div>
<!-- Stats Row -->
<!-- Main Content Area -->
<div class="bg-surface/20 rounded-xl border border-border-color p-8">
<div class="flex items-center gap-3 mb-8">
<svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" /></svg>
<h2 class="text-slate-100 text-xl font-bold tracking-tight">Thông tin sản phẩm</h2>
</div>
<form action="/admin/add" method="POST" enctype="multipart/form-data" id="addForm">
<!-- Upload Area -->
<label for="video" class="flex flex-col items-center gap-6 rounded-xl border-2 border-dashed border-slate-700 bg-surface/10 px-6 py-16 mb-10 group hover:border-primary/50 transition-colors cursor-pointer block relative">
    <input type="file" id="video" name="video" accept="video/mp4,video/webm" required class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" onchange="document.getElementById('fileName').textContent = this.files[0] ? this.files[0].name : 'Chưa chọn file'">
    <div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
        <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0 3 3m-3-3-3 3M6.75 19.5a4.5 4.5 0 0 1-1.41-8.775 5.25 5.25 0 0 1 10.233-2.33 3 3 0 0 1 3.758 3.848A3.752 3.752 0 0 1 18 19.5H6.75Z" /></svg>
    </div>
    <div class="flex flex-col items-center gap-2">
        <p class="text-slate-100 text-lg font-bold text-center" id="fileName">Kéo và thả video vào đây</p>
        <p class="text-slate-400 text-sm font-normal text-center max-w-sm">Hoặc nhấp để chọn tệp từ máy tính của bạn<br/>(Định dạng hỗ trợ: MP4, WebM - Tối đa 50MB)</p>
    </div>
</label>
<!-- Form Fields -->
<div class="space-y-6">
    <div class="flex flex-col gap-2">
        <label class="text-slate-300 text-sm font-semibold" for="title">Tiêu đề</label>
        <input class="w-full bg-surface/40 border border-border-color rounded-lg px-4 py-3 text-slate-100 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all placeholder:text-slate-600" id="title" name="title" required placeholder="Nhập tiêu đề sản phẩm..." type="text"/>
    </div>
    <div class="flex flex-col gap-2">
        <label class="text-slate-300 text-sm font-semibold" for="description">Mô tả</label>
        <textarea class="w-full bg-surface/40 border border-border-color rounded-lg px-4 py-3 text-slate-100 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all placeholder:text-slate-600" id="description" name="description" placeholder="Mô tả chi tiết về dự án AI này..." rows="4"></textarea>
    </div>
    <div class="flex flex-col gap-2">
        <label class="text-slate-300 text-sm font-semibold" for="tags">Tags (phân cách bằng dấu phẩy)</label>
        <input class="w-full bg-surface/40 border border-border-color rounded-lg px-4 py-3 text-slate-100 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all placeholder:text-slate-600" id="tags" name="tags" placeholder="AI, Machine Learning, Computer Vision" type="text"/>
    </div>
</div>
<!-- Action Button -->
<div class="mt-10 pt-8 border-t border-border-color flex justify-end">
    <button type="submit" id="submitBtn" class="flex items-center justify-center gap-2 rounded-lg h-12 px-8 bg-primary text-white text-base font-bold hover:bg-primary/90 transition-all shadow-lg shadow-primary/20">
        <div id="submitIcon"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg></div>
        <span id="submitText">Thêm sản phẩm</span>
    </button>
</div>
</form>

<script>
    document.getElementById('addForm').addEventListener('submit', function(e) {
        document.getElementById('submitBtn').disabled = true;
        document.getElementById('submitBtn').classList.add('opacity-70', 'cursor-not-allowed');
        document.getElementById('submitIcon').innerHTML = '<svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>';
        document.getElementById('submitText').innerText = 'Processing...';
    });
</script>
</div>
</div>
</main>

<%- include('partials/admin_footer') %>