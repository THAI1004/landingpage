<%- include('partials/admin_header') %>

<!-- Main Content Area -->
<main class="flex-1 overflow-y-auto px-8 py-8 lg:px-12">
<!-- Header -->
<header class="flex items-center justify-between mb-10">
<div>
<h1 class="text-2xl font-bold tracking-tight text-slate-900 dark:text-white">Chỉnh sửa sản phẩm</h1>
<p class="text-slate-500 dark:text-slate-400 text-sm">Cập nhật thông tin chi tiết cho sản phẩm AI của bạn.</p>
</div>
<div class="flex items-center gap-4">
<div class="relative">
<svg class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" /></svg>
<input class="pl-10 pr-4 py-2 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg text-sm focus:ring-1 focus:ring-primary focus:border-primary outline-none min-w-[300px]" placeholder="Tìm kiếm video..." type="text"/>
</div>
<a href="/logout" class="flex items-center justify-center px-4 py-2 text-sm font-medium rounded-lg bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 text-rose-500 hover:bg-rose-50 dark:hover:bg-rose-500/10 transition-colors">
    Đăng xuất
</a>
</div>
</header>
<!-- Quick Stats -->
<!-- Upload Form & Video Management -->
<div class="grid grid-cols-1 xl:grid-cols-5 gap-10">
<!-- Upload Form -->
<section class="flex flex-col gap-6 xl:col-span-3 xl:col-start-2">
<div class="flex items-center gap-2 mb-2">
<svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L6.832 19.82a4.5 4.5 0 0 1-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 0 1 1.13-1.897L16.863 4.487Zm0 0L19.5 7.125" /></svg>
<h2 class="text-lg font-bold">Thông tin sản phẩm</h2>
</div>
<div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-8 flex flex-col gap-6">
<form action="/admin/edit/<%= product.id %>" method="POST" enctype="multipart/form-data" id="updateForm" class="flex flex-col gap-6">
<!-- Drag and Drop Area -->
<label for="video" class="border-2 border-dashed border-slate-200 dark:border-slate-700 rounded-xl p-10 flex flex-col items-center justify-center gap-4 bg-slate-50/50 dark:bg-slate-800/30 group cursor-pointer hover:border-primary/50 transition-all relative block">
    <input type="file" id="video" name="video" accept="video/mp4,video/webm" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" onchange="document.getElementById('fileName').textContent = this.files[0] ? this.files[0].name : 'Đã chọn file gốc'">
    <div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
        <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15.91 11.672a.375.375 0 0 1 0 .656l-5.603 3.113a.375.375 0 0 1-.557-.328V8.887c0-.286.307-.466.557-.327l5.603 3.112Z" /></svg>
    </div>
    <div class="text-center">
        <p class="text-sm font-semibold" id="fileName">Click hoặc kéo thả để thay đổi video</p>
        <p class="text-xs text-slate-500 mt-1">MP4, WebM (Tối đa 50MB). Bỏ trống nếu muốn giữ nguyên video cũ.</p>
    </div>
</label>
<!-- Inputs -->
<div class="flex flex-col gap-4">
    <div class="flex flex-col gap-1.5">
        <label class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Tiêu đề</label>
        <input class="w-full px-4 py-3 bg-transparent border border-slate-200 dark:border-slate-700 rounded-lg focus:ring-1 focus:ring-primary focus:border-primary outline-none transition-all placeholder:text-slate-400 dark:placeholder:text-slate-600" placeholder="Nhập tên project..." type="text" name="title" required value="<%= product.title %>"/>
    </div>
    <div class="flex flex-col gap-1.5">
        <label class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Mô tả</label>
        <textarea class="w-full px-4 py-3 bg-transparent border border-slate-200 dark:border-slate-700 rounded-lg focus:ring-1 focus:ring-primary focus:border-primary outline-none transition-all placeholder:text-slate-400 dark:placeholder:text-slate-600" placeholder="Mô tả ngắn gọn về video AI..." rows="3" name="description"><%= product.description %></textarea>
    </div>
    <div class="flex flex-col gap-1.5">
        <label class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Tags</label>
        <input class="w-full px-4 py-3 bg-transparent border border-slate-200 dark:border-slate-700 rounded-lg focus:ring-1 focus:ring-primary focus:border-primary outline-none transition-all placeholder:text-slate-400 dark:placeholder:text-slate-600" placeholder="AI, Machine Learning, Automation..." type="text" name="tags" value="<%= product.tech_tags %>"/>
    </div>
</div>
<button type="submit" id="submitBtn" class="w-full py-4 bg-primary text-white font-bold rounded-lg hover:bg-primary/90 transition-colors shadow-lg shadow-primary/20 flex items-center justify-center gap-2">
    <span id="submitText">Cập nhật</span>
    <div id="submitIcon"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg></div>
</button>
</form>

<script>
    document.getElementById('updateForm').addEventListener('submit', function(e) {
        document.getElementById('submitBtn').disabled = true;
        document.getElementById('submitBtn').classList.add('opacity-70', 'cursor-not-allowed');
        document.getElementById('submitIcon').innerHTML = '<svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>';
        document.getElementById('submitText').innerText = 'Processing...';
    });
</script>
</div>
</section>
<!-- Management Table -->
</main>

<%- include('partials/admin_footer') %>