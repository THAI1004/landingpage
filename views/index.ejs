<!DOCTYPE html>

<html lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Roboto+Mono:wght@400;700&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#0d6efd",
                        "accent": "#ff7a00",
                        "surface": "#ffffff",
                        "surface-2": "#f5f7fb",
                        "border-soft": "#e6eaf2"
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"],
                        "mono": ["Roboto Mono", "monospace"],
                        "code": ["JetBrains Mono", "monospace"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                },
            },
        }
    </script>
<style>
        .grid-bg {
            background-image: radial-gradient(ellipse at top, rgba(13, 110, 253, 0.10), transparent 55%),
                              radial-gradient(ellipse at bottom, rgba(255, 122, 0, 0.08), transparent 55%);
        }
        .hero-shell {
            padding-top: clamp(3.5rem, 6vh, 5.25rem);
            padding-bottom: clamp(1.75rem, 4vh, 3rem);
        }
        .projects-shell {
            padding-top: clamp(1.25rem, 3vh, 2.25rem);
        }
        .neon-glow {
            box-shadow: 0 12px 24px rgba(13, 110, 253, 0.18);
            border: 1px solid rgba(13, 110, 253, 0.22);
        }
        .bento-card {
            background: #ffffff;
            border: 1px solid rgba(226, 232, 240, 0.9);
            border-radius: 0.75rem;
            box-shadow: 0 10px 30px rgba(2, 6, 23, 0.06);
        }
        .infinite-scroll {
            display: flex;
            width: fit-content;
        }
    </style>
</head>
<body class="bg-surface-2 font-display text-slate-900 selection:bg-primary/15">
<!-- Grid Lines Overlay -->
<div class="fixed inset-0 grid-bg pointer-events-none z-0"></div>
<div class="relative z-10">
<!-- Navigation -->
<nav class="border-b border-border-soft bg-white/85 backdrop-blur-md sticky top-0 z-50">
<div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
<div class="flex items-center gap-8">
<div class="flex items-center gap-2">
<svg class="w-8 h-8 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m6.75 7.5 3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0 0 21 18V6a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 6v12a2.25 2.25 0 0 0 2.25 2.25Z" /></svg>
<span class="font-mono text-xl font-bold tracking-tighter uppercase">Bee IT</span>
</div>
<div class="hidden md:flex items-center gap-8 text-sm text-slate-600">
    <a class="hover:text-primary transition-colors cursor-pointer" onclick="document.getElementById('projects-grid').scrollIntoView({ behavior: 'smooth' })">Dự án</a>
</div>
</div>
<div class="flex items-center gap-4">
<form action="/" method="GET" class="relative group">
    <input type="text" name="q" value="<%= locals.searchQuery || '' %>" placeholder="Tìm kiếm dự án..." class="bg-white border border-border-soft rounded-full pl-4 pr-10 py-1.5 text-sm focus:outline-none focus:border-primary/40 focus:ring-2 focus:ring-primary/15 transition-all w-48 md:w-64 placeholder-slate-400">
    <button type="submit" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-500 hover:text-slate-900 transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" /></svg>
    </button>
</form>
</div>
</div>
</nav>
<!-- Hero Section -->
<section class="hero-shell max-w-7xl mx-auto px-6 flex flex-col items-center text-center">
<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/5 border border-primary/15 text-primary text-xs font-bold mb-8 uppercase tracking-widest"><span class="relative flex h-2 w-2"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-35"></span><span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span></span> Nền tảng quản lý & giới thiệu dự án</div>
<h1 class="font-mono text-4xl md:text-7xl font-bold mb-6 tracking-tight max-w-4xl"> <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent">Kiến tạo Tương lai bằng Mã nguồn</span></h1>
<p class="text-slate-600 text-lg md:text-xl max-w-2xl mb-12 font-display">Điều phối mạng thần kinh tiên tiến cho kỹ thuật hiệu suất cao. Chúng tôi thu hẹp khoảng cách giữa các thuật toán trừu tượng và trí tuệ nhân tạo cấp sản xuất.</p>
<div class="flex flex-col sm:flex-row gap-4">
    <button onclick="document.getElementById('projects-grid').scrollIntoView({ behavior: 'smooth' })" class="neon-glow px-8 py-4 bg-primary text-white font-bold rounded-xl hover:bg-primary/95 transition-all flex items-center gap-2 cursor-pointer">Khám phá Dự án <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg></button>
</div>

<form action="/" method="GET" class="w-full max-w-4xl mt-10">
    <div class="bg-white border border-border-soft rounded-2xl shadow-sm p-3 md:p-4 flex flex-col md:flex-row gap-3 md:gap-4 items-stretch md:items-center">
        <div class="flex-1">
            <label class="block text-left text-xs font-semibold text-slate-600 mb-1">Từ khóa</label>
            <input type="text" name="q" value="<%= locals.searchQuery || '' %>" placeholder="Nhập tên dự án / công nghệ..." class="w-full bg-surface-2 border border-border-soft rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary/40 focus:ring-2 focus:ring-primary/15 placeholder-slate-400">
        </div>
        <button type="submit" class="neon-glow md:mt-6 bg-primary text-white font-bold rounded-xl px-6 py-3 hover:bg-primary/95 transition-colors whitespace-nowrap">
            Tìm kiếm
        </button>
    </div>
</form>
</section>
<!-- Bento Grid Project Showcase -->
<section id="projects-grid" class="projects-shell max-w-7xl mx-auto px-6 pb-24 scroll-mt-20">
<div class="mb-10">
    <div class="h-px w-full bg-gradient-to-r from-transparent via-border-soft to-transparent"></div>
</div>
<div class="flex justify-between items-end mb-12">
<div>
<h2 class="text-3xl font-mono font-bold">Sản phẩm Tiêu biểu</h2>
<p class="text-slate-500 mt-2">Nghiên cứu tích cực và triển khai sản xuất.</p>
</div>
<div class="flex gap-2">
<button class="w-10 h-10 flex items-center justify-center border border-border-soft rounded-lg hover:bg-slate-50 text-slate-600 hover:text-slate-900 transition-colors"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg></button>
<button class="w-10 h-10 flex items-center justify-center border border-border-soft rounded-lg hover:bg-slate-50 text-slate-600 hover:text-slate-900 transition-colors"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg></button>
</div>
</div>
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
    <% if (typeof products !== 'undefined' && products.length > 0) { %>
        <% products.forEach(product => { %>
        <!-- Dynamic Card -->
        <div class="bento-card group overflow-hidden relative h-[clamp(280px,38vh,400px)] cursor-pointer" onclick="openVideoModal('<%= product.video_url %>', '<%= product.title %>')">
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/30 via-transparent to-transparent z-10 pointer-events-none transition-opacity group-hover:opacity-100"></div>
            <div class="w-full h-full bg-slate-100 flex items-center justify-center relative">
                <% if (product.video_url) { %>
                    <video class="w-full h-full object-cover opacity-95 group-hover:scale-105 transition-all duration-700" data-alt="<%= product.title %>" loop muted onmouseover="this.play()" onmouseout="this.pause()">
                        <source src="<%= product.video_url %>" type="video/mp4"/>
                    </video>
                    <!-- Play icon overlay on hover -->
                    <div class="absolute inset-0 z-20 flex items-center justify-center text-white opacity-0 group-hover:opacity-100 transition-opacity transform scale-75 group-hover:scale-100 duration-300">
                        <svg class="w-16 h-16 drop-shadow-lg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15.91 11.672a.375.375 0 0 1 0 .656l-5.603 3.113a.375.375 0 0 1-.557-.328V8.887c0-.286.307-.466.557-.327l5.603 3.112Z" /></svg>
                    </div>
                <% } else { %>
                    <div class="text-primary opacity-20"><svg class="w-32 h-32" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 0 0 2.25-2.25V6.75a2.25 2.25 0 0 0-2.25-2.25H6.75A2.25 2.25 0 0 0 4.5 6.75v10.5a2.25 2.25 0 0 0 2.25 2.25Z" /></svg></div>
                <% } %>
            </div>
            <div class="absolute bottom-0 left-0 p-6 z-20">
                <div class="flex gap-2 mb-3">
                    <% if (product.tech_tags) { %>
                        <% product.tech_tags.split(',').forEach(tag => { %>
                            <span class="px-2 py-0.5 bg-orange-50 text-orange-700 text-[10px] rounded-md border border-orange-200 uppercase font-bold"><%= tag.trim() %></span>
                        <% }) %>
                    <% } %>
                </div>
                <h3 class="text-xl font-bold mb-2 text-slate-900"><%= product.title %></h3>
                <p class="text-slate-700 text-xs"><%= product.description %></p>
            </div>
        </div>
        <% }) %>
    <% } else { %>
        <p class="text-slate-500 text-center col-span-3 py-10">Chưa có sản phẩm nào được tải lên.</p>
    <% } %>
</div>

<!-- Pagination -->
<% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
    <div class="flex items-center justify-center gap-2 mt-12">
        <!-- Previous Page -->
        <% if (currentPage > 1) { %>
            <a href="/?page=<%= currentPage - 1 %><%= searchQuery ? '&q=' + searchQuery : '' %>" class="w-10 h-10 flex items-center justify-center border border-border-soft rounded-lg hover:bg-slate-50 transition-colors text-slate-600 hover:text-slate-900">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
            </a>
        <% } else { %>
            <button disabled class="w-10 h-10 flex items-center justify-center border border-border-soft text-slate-300 rounded-lg cursor-not-allowed">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
            </button>
        <% } %>

        <!-- Page Numbers -->
        <% for(let i = 1; i <= totalPages; i++) { %>
            <% if (i === currentPage) { %>
                <span class="w-10 h-10 flex items-center justify-center border border-primary bg-primary/10 text-primary font-bold rounded-lg"><%= i %></span>
            <% } else { %>
                <a href="/?page=<%= i %><%= searchQuery ? '&q=' + searchQuery : '' %>" class="w-10 h-10 flex items-center justify-center border border-border-soft hover:bg-slate-50 transition-colors rounded-lg text-slate-700"><%= i %></a>
            <% } %>
        <% } %>

        <!-- Next Page -->
        <% if (currentPage < totalPages) { %>
            <a href="/?page=<%= currentPage + 1 %><%= searchQuery ? '&q=' + searchQuery : '' %>" class="w-10 h-10 flex items-center justify-center border border-border-soft rounded-lg hover:bg-slate-50 transition-colors text-slate-600 hover:text-slate-900">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
            </a>
        <% } else { %>
            <button disabled class="w-10 h-10 flex items-center justify-center border border-border-soft text-slate-300 rounded-lg cursor-not-allowed">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
            </button>
        <% } %>
    </div>
<% } %>
</section>
